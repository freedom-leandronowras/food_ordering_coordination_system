{
  "name": "food_ordering_coordination_system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,api,vendor -c cyan,magenta,yellow \"pnpm dev:web\" \"pnpm api:server\" \"pnpm vendor:server\"",
    "dev:web": "next dev",
    "dev:vc": "concurrently -k -n vc,api,vendor -c cyan,magenta,yellow \"pnpm dev:vc:web\" \"pnpm api:server\" \"pnpm vendor:server\"",
    "dev:vc:web": "vc dev",
    "api:server": "cd api && go run .",
    "vendor:server": "sh -c 'json-server --watch \"$VENDOR_API_DB_PATH\" --port \"$VENDOR_API_PORT\"'",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.38.2",
    "@opentelemetry/api": "^1.9.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@vercel/otel": "^2.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.1.6",
    "pino": "^10.3.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "json-server": "1.0.0-beta.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
